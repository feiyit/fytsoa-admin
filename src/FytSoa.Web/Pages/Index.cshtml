<!-- Cases Section -->
<section id="cases" class="pt-0">
    <div class="container">
        <h2 class="section-title">精选案例</h2>
        <p class="section-subtitle">我们的作品遍布各行各业，每一个项目都倾注心血</p>

        <div class="filter-buttons fade-in">
            <a href="/cases">
            <button class="filter-btn active" data-filter="all">全部</button></a>
            @{
                var cclass = column.Where(m => m.ParentId == 1529313037205508096).ToList();
                foreach (var item in cclass)
                {
                    <a href="/cases/@item.EnTitle"><button class="filter-btn" data-filter="@item.Id">@item.Title</button></a>
                }
            }
        </div>

        <div class="row" id="casesContainer">

            @foreach (var item in cases)
            {
                <div class="col-lg-4 col-md-6 fade-in case-item" data-category="@item.ColumnId">
                    <div class="case-card tilt-card">
                        <div class="case-image-wrapper">
                            <img src="@item.ImgUrl.UrlReplace()" alt="@item.Title"
                                 class="case-image" loading="lazy">
                            <div class="case-overlay">
                                <a href="/cases/detail/@item.Id" class="case-overlay-btn">查看详情</a>
                            </div>
                        </div>
                        <div class="case-content">
                            @foreach (var row in item.Tag)
                            {
                                <span class="case-category">@row</span>
                            }
                            <h3>@item.Title</h3>
                            <p>@item.Summary</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- News Section -->
<section id="news" class="bg-light">
    <div class="container">
        <h2 class="section-title">最新资讯</h2>
        <p class="section-subtitle">了解最新的技术趋势与行业动态</p>

        <div class="row">

            @foreach (var item in article)
            {
                <div class="col-lg-4 col-md-6 fade-in mb-4">
                    <article class="news-item">
                        <div class="news-item-image">
                            <img src="@item.ImgUrl.UrlReplace()" alt="@item.Title"
                                 loading="lazy">
                            <span class="news-item-date">@item.PublishTime.ToShortDateString()</span>
                        </div>
                        <div class="news-item-content">
                            <div class="news-item-tags">
                                @foreach (var tag in item.Tag)
                                {
                                    <span class="news-tag">@tag</span>
                                }
                            </div>
                            <h3 class="news-item-title">@item.Title</h3>
                            <p class="news-item-desc">
                                @item.Summary</p>
                            <div class="news-item-meta">
                                <span><i class="far fa-eye"></i> @item.Hits</span>
                                <a href="/dynamic/detail/@item.Id" class="news-read-more">查看详情
                                    <i
                                        class="fas fa-arrow-right"></i></a>
                            </div>
                        </div>
                    </article>
                </div>
            }
        </div>

        <div class="text-center mt-4">
            <a href="/dynamic" class="cta-button">
                查看更多资讯 <i class="fas fa-arrow-right ms-2"></i>
            </a>
        </div>
