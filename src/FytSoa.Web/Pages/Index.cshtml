@page
@using FytSoa.Application.Cms
@using FytSoa.Common.Param
@model IndexModel
@inject CmsColumnService _columnService
@inject CmsArticleService _articleService
@{
    
    ViewData["Title"] = Site.CurrentSite.SeoTitle;
    ViewData["Key"] = Site.CurrentSite.SeoKey;
    ViewData["Desc"] = Site.CurrentSite.SeoDescribe;
    ViewData["Nav"] = 0;
    var column = _columnService.GetListAsync(new WhereParam()).Result;
    var caseColumn = column.Where(m=>m.ParentId== 1529313037205508096).Select(m=>m.Id).ToList();
    var cases = _articleService.PagesAsync(new CmsArticleParam { Limit = 9,ColumnList= caseColumn }).Result.Items;
    var articleColumn = column.Where(m => m.ParentId == 1529313081493164034).Select(m=>m.Id).ToList();
    var article= _articleService.PagesAsync(new CmsArticleParam() { Limit = 12,ColumnList= articleColumn }).Result.Items;
}
